# =============================================================================
# VERCEL + NEON PRODUCTION ENVIRONMENT
# =============================================================================

# Database (Neon PostgreSQL — get from https://console.neon.tech)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.us-east-2.aws.neon.tech/smartcopons?sslmode=require"

# App Security (generate with: openssl rand -hex 32)
APP_SECRET="REPLACE_WITH_64_CHAR_HEX_STRING"

# Admin Account (only used for initial seed)
ADMIN_EMAIL="admin@smartcopons.com"
ADMIN_PASSWORD="REPLACE_WITH_STRONG_PASSWORD"

# App URL (your domain on Vercel)
NEXT_PUBLIC_APP_URL="https://sa.smartcopons.com"

# Node environment
NODE_ENV="production"
